# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scaffold_spring_dev
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_POOL_SIZE=20
DB_POOL_OVERFLOW=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_password_here
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# JWT
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_ACCESS_EXPIRATION_MS=300000
JWT_REFRESH_EXPIRATION_MS=604800000

# CORS（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=admin-uploads
MINIO_SECURE=false

# 日志保留天数
API_LOG_RETENTION_DAYS=30
OPERATION_LOG_RETENTION_DAYS=90
LOGIN_LOG_RETENTION_DAYS=90
ERROR_LOG_RETENTION_DAYS=60
LOG_STORE_RESPONSE_BODY=false

# 文件
RECYCLE_BIN_RETENTION_DAYS=7

# 服务器
APP_PORT=8000
DEBUG=false
