<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.scaffold.admin.mapper.AdminApiLogMapper">

    <resultMap id="apiLogWithName" type="com.scaffold.admin.model.entity.AdminApiLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="username" property="username"/>
        <result column="method" property="method"/>
        <result column="path" property="path"/>
        <result column="query_params" property="queryParams"/>
        <result column="request_body" property="requestBody"/>
        <result column="response_code" property="responseCode"/>
        <result column="response_body" property="responseBody"/>
        <result column="duration_ms" property="durationMs"/>
        <result column="ip" property="ip"/>
        <result column="user_agent" property="userAgent"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="api_name" property="apiName"/>
    </resultMap>

    <sql id="selectWithApiName">
        SELECT l.*,
               p.name AS api_name
        FROM admin_api_log l
        LEFT JOIN admin_permission p
            ON p.method = l.method
            AND p.type = 'api'
            AND p.is_deleted = 0
            AND l.path ~ ('^' || regexp_replace(p.path, '\{[^}]+\}', '[^/]+', 'g') || '$')
        WHERE l.is_deleted = 0
    </sql>

    <select id="selectPageWithApiName" resultMap="apiLogWithName">
        <include refid="selectWithApiName"/>
        <if test="keyword != null and keyword != ''">
            AND (l.path LIKE CONCAT('%', #{keyword}, '%')
                 OR l.username LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="method != null and method != ''">
            AND l.method = #{method}
        </if>
        <if test="startTime != null and startTime != ''">
            AND l.create_time &gt;= #{startTime}::timestamp
        </if>
        <if test="endTime != null and endTime != ''">
            AND l.create_time &lt;= #{endTime}::timestamp
        </if>
        ORDER BY l.create_time DESC
    </select>

    <select id="selectByIdWithApiName" resultMap="apiLogWithName">
        <include refid="selectWithApiName"/>
        AND l.id = #{id}
    </select>

</mapper>
